# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bids_bazar
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT (RS256 — generate with: openssl genrsa 2048 | tee private.pem; openssl rsa -pubout -in private.pem -out public.pem)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=64_hex_chars_here

# File uploads
UPLOAD_BASE_DIR=./uploads

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@example.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM="BidsBazar <noreply@example.com>"

# Frontend (used in email links)
APP_FRONTEND_URL=http://localhost:3000

# Bidding & Auction Lifecycle
BIDDING_DURATION_HOURS=24
PAYMENT_WINDOW_HOURS=18
BID_INCREMENT_MIN_FLAT=5
BID_INCREMENT_PERCENT=0.10
